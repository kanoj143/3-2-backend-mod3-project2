{
  "name": "database-migrations-demo",
  "version": "1.0.0",
  "description": "Database migrations with Node.js and Express",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node src/migrations/migration-runner.js",
    "migrate:down": "node src/migrations/migration-runner.js down",
    "migrate:create": "node src/migrations/migration-runner.js create"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.8.9"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
